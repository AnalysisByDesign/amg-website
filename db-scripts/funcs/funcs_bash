################################################################################
# AmG_Syslog - Writes a message to the syslog...
function AmG_Syslog () {
	msgType=$2
	[ "${msgType}" = "" ] && msgType="bash/${scriptName}"
	logger -p "user.notice" -t "${msgType}" "$1"
}


################################################################################
# AmG_Message - Displays the input parameter with a date/time stamp prefix
function AmG_Message () {
	thedate=`date +"%d-%b-%Y,%H:%M:%S"`
	# This is a normal message statement - always show
	echo "${thedate},$1"
	# And write out to syslog if we need to
	AmG_Syslog "$1" "$2"
}


################################################################################
# AmG_Verbose - Displays the input parameter with a date/time stamp prefix
#				if the relevant variable is set
function AmG_Verbose () {
	if [ "Y" = "${verbose}" -o "Y" = "${v_verbose}" ]; then
		# This is a 'verbose' debug statement
		msgType=$2
		[ "${msgType}" = "" ] && msgType="bash/${scriptName}/verbose"
		AmG_Message "$1" ${msgType}
	fi
}


################################################################################
# AmG_V_Verbose - Displays the input parameter with a date/time stamp prefix
#				if the relevant variable is set
function AmG_V_Verbose () {
	if [ "Y" = "${v_verbose}" ]; then
		# This is a 'very verbose' debug statement
		# Print only if v_verbose is set
		msgType=$2
		[ "${msgType}" = "" ] && msgType="bash/${scriptName}/v_verbose"
		AmG_Message $1 ${msgType}
	fi
}


################################################################################
# microtime - returns a time-stamp for monitoring purposes
function microtime() {
	date +"%s"
}
startTime=`microtime`


################################################################################
# AmG_GetDuration - returns the interval between two passed in times
function AmG_GetDuration() {
	startTime=$1; endTime=$2
	[ "" = "${startTime}" ] && startTime=`microtime`
	[ "" = "${endTime}" ] && endTime=`microtime`
	echo $((endTime - startTime))
}


