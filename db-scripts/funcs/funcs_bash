#!/bin/bash
################################################################################
# Set up any functions that might be required in our scripts
################################################################################

scriptName=`basename $0 2>/dev/null`
[ "" = "${scriptName}" ] && scriptName=$$
[ "" = "${verbose}" ] && verbose="N"

# Prepare the paths we are going to use
basePath=`git rev-parse --show-toplevel`
funcPath="${basePath}/funcs"

dataPath="/data"
tmpPath="${dataPath}/tmp"
logPath="${dataPath}/logs"
mkdir -p ${logPath} ${tmpPath}

# Some generic variables for use later
   userIP=`echo ${SSH_CLIENT} | awk '{print $1}'`
  theDate=`date +"%Y%m%d"`
  theTime=`date +"%H%M%S"`
 dateTime=`date +"%Y-%m-%d,%H:%M:%S"`
   theDTS=${theDate}-${theTime}
   dryRun="N"

# Include our AWS functions
. ${funcPath}/funcs_aws

# Prepare some filenames
[ "" = "${logFile}" ] && logFile="${logPath}/${scriptName}.log"
[ "" = "${lockFile}" ] && lockFile="${tmpPath}/${scriptName}.lock"

################################################################################
# Where are we going to log stuff?
if [ ! -t 1 ]; then
	# Close STDOUT & STDERR FD
	exec 1<&-;			exec 2<&-
	# Redirect STDOUT & STDERR to logFile
	exec 1>>${logFile};	exec 2>>${logFile}
fi

################################################################################
# AmG_ObtainLock - Obtains a lock file based on the calling program name...
function AmG_ObtainLock () {
	AmG_Verbose "Locking with ${lockFile}"

	# Create the lockfile
	lockfile-create --use-pid --lock-name ${lockFile} #2>/dev/null
	ret=$?

	if [ ${ret} -ne 0 ]; then
		AmG_Message "Obtaining lockfile ${lockFile} failed... - already running?"
		exit ${ret}
	fi

	# Constantly touch the lockfile
	lockfile-touch --lock-name ${lockFile} & #2>/dev/null
	lockStatus=$!
}


################################################################################
# AmG_RemoveLock - Obtains a lock file based on the calling program name...
function AmG_RemoveLock () {
	AmG_Verbose "Removing lock ${lockFile}"

	kill "${lockStatus}" > /dev/null 2>&1
	lockfile-remove --lock-name ${lockFile} > /dev/null 2>&1
}


################################################################################
# The exit_script function will be used to catch unwanted exits of the script
# and to perform any cleanups or email output
