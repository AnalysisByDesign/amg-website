APP_NAME="AnalyseMy.Golf (Old)"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_DATABASE=amg_master

# config/database.php uses a read/write split with non-standard env var names.
# DB_HOST/DB_USERNAME/DB_PASSWORD are NOT used — set these instead:
DB_WRITER_HOST=amg-db
DB_WRITER_PORT=3306
DB_WRITER_USERNAME=homestead
DB_WRITER_PASSWORD=secret
DB_READER_HOST=amg-db
DB_READER_PORT=3306
DB_READER_USERNAME=homestead
DB_READER_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------------------
# Laravel Spark — REQUIRED to run composer install
# -----------------------------------------------------------------------
# 1. Log in at https://spark.laravel.com/dashboard
# 2. Copy your API token from the dashboard
# 3. Add auth to Composer so it can pull the private Spark package:
#       composer config http-basic.spark.laravel.com your@email.com YOUR_TOKEN
#    This writes to ~/.composer/auth.json — mount that file into the container
#    by adding to docker-compose.yml volumes: - ~/.composer:/root/.composer
# -----------------------------------------------------------------------
SPARK_KEY=your-spark-key-here

# Stripe — use test keys for local. Spark billing runs through Stripe.
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
CASHIER_CURRENCY=gbp
CASHIER_CURRENCY_LOCALE=en_GB

# Sentry (optional — leave blank for local)
SENTRY_LARAVEL_DSN=

# Mail — 'log' driver writes to storage/logs/laravel.log (no mail server needed)
MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@analysemy.golf
MAIL_FROM_NAME="${APP_NAME}"

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
